# PermitIQ Environment Configuration
# Copy this file to .env and customize as needed

# API Configuration
PERMITIQ_API_URL=http://127.0.0.1:8000
API_PORT=8000
FRONTEND_PORT=8501

# Tesseract OCR (macOS default via Homebrew)
TESSERACT_PATH=/opt/homebrew/bin/tesseract

# Data Paths (relative to project root)
GEOJSON_PATH=boston_parcels_zoning.geojson
ZBA_DATA_PATH=zba_cases_cleaned.csv
PROPERTY_ASSESSMENT_PATH=property_assessment_fy2026.csv
MODEL_PATH=api/zba_model.pkl

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Database (PostGIS — optional, falls back to in-memory GeoJSON)
DATABASE_URL=postgresql://postgres:permitiq123@localhost/permitiq

# API Authentication (optional — leave blank for open/demo mode)
# Set to enable API key auth on prediction endpoints
# PERMITIQ_API_KEY=your-secret-key-here
