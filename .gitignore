# PermitIQ .gitignore — TRANSFER BRANCH
# This branch includes data, docs, and configs for full project transfer.
# Files over GitHub's 100MB limit are excluded (use cloud storage for those).

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environment (rebuild with: pip install -r requirements.txt)
zoning-env/

# ---- FILES OVER 100MB (transfer via cloud storage) ----
