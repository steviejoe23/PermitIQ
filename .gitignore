# zba_model_v2.pkl              219MB
# api/zba_model.pkl             219MB (copy of zba_model_v2.pkl)
# boston_parcels_zoning.geojson   81MB
# property_assessment_fy2026.csv 76MB
# pdfs/                         4.2GB
# model_history/                1.7GB
# parcels_2025/                  91MB
# parcels_2025_clean/           118MB
building_permits.csv
zba_model_v2.pkl
api/zba_model.pkl
boston_parcels_zoning.geojson
property_assessment_fy2026.csv
pdfs/
model_history/
parcels_2025/
