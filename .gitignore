# PermitIQ .gitignore — TRANSFER BRANCH
# This branch includes data, docs, and configs for full project transfer.
# Files over GitHub's 100MB limit are excluded (use cloud storage for those).

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environment (rebuild with: pip install -r requirements.txt)
zoning-env/

# ---- LARGE FILES NOW HANDLED BY GIT LFS ----
# building_permits.csv, *.pkl, *.geojson, pdfs/, model_history/, parcels_2025*

# GIS shapefiles (raw source data — in parcels dirs above)
*.shp
*.shx
*.dbf
*.prj
*.sbn
*.sbx
*.cpg
*.shp.xml
Boston Zoning GCOD Clean/
Coastal Flood Resilience Overlay District Clean/
boston_zoning_district_clean/

# Zip archives (raw downloads — can re-download)
*.zip

# Jupyter checkpoints (auto-generated)
.ipynb_checkpoints/
.virtual_documents/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment secrets (never commit)
.env
.env.local

# Logs
*.log
overnight_log.txt
overnight_log.txt~

# Test cache
.pytest_cache/
htmlcov/
.coverage

# Docker overrides
docker-compose.override.yml

# Generated artifacts
calibration_report.png
calibration_report.txt
model_diagnostics.png
dashboard.html

# Auth usage logs
api/usage.log

# OCR intermediates
ocr_output/
ocr_checkpoint.json
